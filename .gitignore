###############################################
# Root .gitignore — JS/TS/React + RN + iOS/Android + Java
# Keep this list scoped to build artifacts, caches, secrets and IDE files.
###############################################

# Node/TypeScript/React web
node_modules/
dist/
build/
temp/
tmp/
.cache/
.parcel-cache/
*.tsbuildinfo
next-env.d.ts

# Next.js
.next/
out/

# Expo / React Native
.expo/
.expo-shared/
*.expo
.turbo/

# Android (Gradle/Studio)
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/.idea/
*.iml
*.jks
*.keystore

# iOS (Xcode/CocoaPods)
ios/build/
ios/DerivedData/
ios/Pods/
ios/*.xcworkspace/xcuserdata/
ios/*.xcodeproj/project.xcworkspace/xcuserdata/
*.xcuserstate
*.xccheckout
*.mode1v3
*.mode2v3
*.perspectivev3
*.pbxuser
!default.pbxuser
*.swiftpm
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# Java (Maven/Gradle)
target/
.gradle/
**/build/
*.class

# Testing & coverage
coverage/

# Env files (keep template .env.example in repo instead)
.env
.env*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Vercel
.vercel

# OS / Editors
.DS_Store
.idea/
.vscode/
*.pem

# Project-specific ignores
mobile/.idea/
mobile/.claude/